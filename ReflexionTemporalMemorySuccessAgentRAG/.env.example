# Example environment variables required to run the project.
# Copy to .env and fill in real values before running.

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=judgements
PINECONE_DIMENSION=256
PINECONE_METRIC=cosine

# Yandex Cloud (for embeddings/vision)
YANDEX_API_KEY=
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_QUERY_EMBED_MODEL=text-search-query/latest
YANDEX_DOC_EMBED_MODEL=text-search-doc/latest

# Gemini / Google (if used)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (optional local provider)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Execution / behavior flags
ENABLE_OCR_FALLBACK=0
REFLEXION_ENABLE_SELF_REFLECTION=1
REFLEXION_ENABLE_MULTI_LEVEL_REFLECTION=1
